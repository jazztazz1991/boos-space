generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["boos_garden"]
}

model User {
  id       String  @id @default(cuid())
  username String  @unique
  password String
  entries  Entry[]

  @@schema("boos_garden")
}

enum DayType {
  GOOD
  TOUGH
  SELF_CARE

  @@schema("boos_garden")
}

model Entry {
  id        String   @id @default(cuid())
  date      DateTime
  dayType   DayType
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, userId])
  @@schema("boos_garden")
}
